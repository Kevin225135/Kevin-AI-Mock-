# Required. The app uses PostgreSQL only; there is no in-memory fallback.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_mock_coach?schema=public"

# Required for JWT access tokens and refresh-session signing.
# Use a long random value in every deployed environment.
AUTH_JWT_SECRET="replace-with-at-least-32-random-characters"
AUTH_ACCESS_TOKEN_TTL_MINUTES="15"
AUTH_REFRESH_TOKEN_TTL_DAYS="30"
DEFAULT_USER_PLAN="FREE"

# Optional seed admin. Set both values before running npm run db:seed.
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""

# Optional. If omitted, V1 runs scoring synchronously in the Next.js API route.
REDIS_URL="redis://localhost:6379"

# Optional AI provider. Use "local", "openai-compatible", or "ark".
AI_PROVIDER="local"

# OpenAI-compatible /chat/completions provider.
AI_API_BASE_URL="https://api.example.com/v1"
AI_API_KEY=""
AI_MODEL="mock-interview-rubric"

# Volcengine Ark Responses API provider.
# Set AI_PROVIDER="ark" and put the real key in .env.local, not in git.
ARK_API_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
ARK_API_KEY=""
ARK_MODEL="doubao-seed-2-0-pro-260215"
